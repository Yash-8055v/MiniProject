# ===============================
# LLM Configuration (Groq)
# ===============================
GROQ_API_KEY=your_groq_api_key_here

# ===============================
# Web Search API
# ===============================
SEARCH_API_KEY=your_serpapi_key_here

# ===============================
# CORS (comma-separated origins)
# ===============================
CORS_ORIGINS=https://your-frontend.vercel.app

# ===============================
# MongoDB Atlas (for Trending Claims)
# ===============================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/truthcrew

# ===============================
# Sarvam AI (STT + TTS, Indian languages)
# ===============================
SARVAM_API_KEY=your_sarvam_api_key_here

# ===============================
# HuggingFace (Media + Audio Deepfake Detection)
# ===============================
HUGGING_FACE_API_TOKEN=your_huggingface_token_here

# ===============================
# Telegram Bot
# ===============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEBSITE_URL=https://yourwebsite.vercel.app
BACKEND_URL=http://localhost:8000

# ===============================
# Resemble AI (Audio Deepfake Detection)
# ===============================
RESEMBLE_DETECT_API_KEY=your_resemble_detect_api_key_here

# ===============================
# SightEngine (AI Image + Deepfake Detection)
# ===============================
SIGHTENGINE_API_USER=your_sightengine_api_user_here
SIGHTENGINE_API_SECRET=your_sightengine_api_secret_here
